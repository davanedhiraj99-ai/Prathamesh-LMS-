# =====================================================
# PRATHAMESH SIR'S LMS - ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your values
# =====================================================

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# JWT Secret (Generate at: https://generate-secret.vercel.app/32)
JWT_SECRET=your-jwt-secret-min-32-chars

# Bunny.net CDN
BUNNY_API_KEY=your-bunny-api-key
BUNNY_LIBRARY_ID=your-bunny-library-id

# Optional: one-time admin bootstrap (used by scripts/create-admin.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPass123!
ADMIN_NAME=Admin

# Environment
NODE_ENV=development

# Frontend
VITE_BUNNY_LIBRARY_ID=your-bunny-library-id
