# =====================================================
# PRATHAMESH SIR'S LMS - SINGLE ENV TEMPLATE
# Copy to `.env` (do not commit `.env`)
# =====================================================

# Backend (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prathamesh_lms

# Backend (Auth)
JWT_SECRET=change-me-generate-32-plus-chars

# Bunny.net (optional for local dev until you need uploads/DRM)
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=

# Optional: one-time admin bootstrap (used by backend/scripts/create-admin.js)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin

# Environment
NODE_ENV=development

# Frontend origin (for backend CORS)
# - Local: http://localhost:5173
# - Vercel: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# Frontend (Vite only exposes vars prefixed with VITE_)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_BUNNY_LIBRARY_ID=
