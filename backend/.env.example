# =====================================================
# PRATHAMESH SIR'S LMS - ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your values
# =====================================================

# Database (PostgreSQL)
# Works with Supabase/Neon/any hosted Postgres. Prefer including `?sslmode=require`.
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# JWT Secret (Generate at: https://generate-secret.vercel.app/32)
JWT_SECRET=your-jwt-secret-min-32-chars

# Bunny.net CDN
BUNNY_API_KEY=your-bunny-api-key
BUNNY_LIBRARY_ID=your-bunny-library-id

# Optional: one-time admin bootstrap (used by scripts/create-admin.js)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin

# Environment
NODE_ENV=development

# Frontend
VITE_BUNNY_LIBRARY_ID=your-bunny-library-id
