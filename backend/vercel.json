{
  "version": 2,
  "name": "prathamesh-sir-lms-backend",
  "builds": [
    {
      "src": "api/[...all].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/[...all].js" },
    { "src": "/", "status": 302, "headers": { "Location": "/api/health" } }
  ]
}
